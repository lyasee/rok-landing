{
  "name": "rok-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "homepage": "https://rok.gg",
  "packageManager": "npm@11.9.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^6.4.7",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "gh-pages": {
      "find-cache-dir": {
        "make-dir": {
          "semver": "^6.3.1"
        }
      }
    },
    "yaml-language-server": {
      "yaml": "^2.9.0"
    }
  },
  "browserslist": {
    "production": [
      "defaults",
      "not IE 11"
    ],
    "development": [
      "last 1 Chrome version",
      "last 1 Firefox version",
      "last 1 Safari version"
    ]
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro"
    ]
  }
}
